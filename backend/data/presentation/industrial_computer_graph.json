    {"id":"device-industrial-computer","name":"工控机","type":"device","domain":"core","level":0,"verificationLevel":"official_document","detail":"工业现场承担监控、数据采集与控制支撑的核心计算设备。","layout":{"x":600,"y":390}},

    {"id":"domain-environment","name":"环境工况异常","type":"domain","domain":"environment","level":1,"verificationLevel":"presentation_seed","detail":"温度、湿度、粉尘与振动等外部工况造成的运行风险。","layout":{"x":250,"y":145}},
    {"id":"domain-power","name":"供电系统故障","type":"domain","domain":"power","level":1,"verificationLevel":"presentation_seed","detail":"市电、电源本体、配电附件与电压监测异常。","layout":{"x":600,"y":95}},
    {"id":"domain-hardware","name":"硬件部件失效","type":"domain","domain":"hardware","level":1,"verificationLevel":"presentation_seed","detail":"散热、存储、主板、监控模块与电池等部件故障。","layout":{"x":960,"y":155}},
    {"id":"domain-maintenance","name":"安装与运维不规范","type":"domain","domain":"maintenance","level":1,"verificationLevel":"presentation_seed","detail":"安装、检修、参数配置和配件使用不规范。","layout":{"x":260,"y":655}},
    {"id":"domain-monitoring","name":"监控告警失效","type":"domain","domain":"monitoring","level":1,"verificationLevel":"presentation_seed","detail":"指示、蜂鸣、监控总线和告警复位链路失效。","layout":{"x":955,"y":650}},

    {"id":"env-temperature","name":"温度超标","type":"fault_category","domain":"environment","level":2,"verificationLevel":"presentation_seed","detail":"环境高温、低温无加温或存储温区超限。","layout":{"x":75,"y":75}},
    {"id":"env-condensation","name":"湿度凝露","type":"fault_category","domain":"environment","level":2,"verificationLevel":"collecting","detail":"高湿和快速温差变化可能造成板卡凝露与腐蚀。","layout":{"x":75,"y":175}},
    {"id":"env-dust","name":"粉尘堵塞","type":"fault_category","domain":"environment","level":2,"verificationLevel":"collecting","detail":"滤网长期不清理或无防尘措施导致进风阻力升高。","layout":{"x":115,"y":285}},
    {"id":"env-vibration","name":"振动冲击","type":"fault_category","domain":"environment","level":2,"verificationLevel":"presentation_seed","detail":"固定不良、搬运不当或现场振动影响机械连接。","layout":{"x":255,"y":325}},
    {"id":"env-high-heat","name":"高温堵风道","type":"fault_mode","domain":"environment","level":3,"verificationLevel":"presentation_seed","detail":"高环境温度叠加风道受阻，导致散热余量不足。","layout":{"x":35,"y":25}},
    {"id":"env-board-moisture","name":"板卡凝露","type":"fault_mode","domain":"environment","level":3,"verificationLevel":"collecting","detail":"凝露可能造成绝缘下降、腐蚀和启动不稳定。","layout":{"x":35,"y":225}},
    {"id":"env-filter-dust","name":"滤网积尘","type":"fault_cause","domain":"environment","level":3,"verificationLevel":"verified_case","knowledgeId":"KB-008","detail":"当前散热案例已验证的进风阻力来源之一；官方资料确认设备配置前置空气滤网。","sourceRefs":[{"documentId":"DOC-ADVANTECH-ACP4000-IPC610-UM-ED6","pages":[33]},{"documentId":"DOC-ADVANTECH-ACP4000-DS-20250317","pages":[1,2]}],"layout":{"x":80,"y":365}},

    {"id":"power-mains","name":"外部市电异常","type":"fault_category","domain":"power","level":2,"verificationLevel":"presentation_seed","detail":"电压超范围、接地缺失或电源线破损。","layout":{"x":420,"y":40}},
    {"id":"power-module","name":"电源本体异常","type":"fault_category","domain":"power","level":2,"verificationLevel":"collecting","detail":"电源老化、冗余单路损坏或替换件不匹配。","layout":{"x":535,"y":185}},
    {"id":"power-distribution","name":"配电附件异常","type":"fault_category","domain":"power","level":2,"verificationLevel":"presentation_seed","detail":"保险丝规格、接线松动和极性错误。","layout":{"x":690,"y":180}},
    {"id":"power-voltage","name":"电压监测异常","type":"fault_category","domain":"power","level":2,"verificationLevel":"presentation_seed","detail":"多路输出偏移或采集接口松动。","layout":{"x":790,"y":45}},
    {"id":"power-aging","name":"电源老化","type":"fault_cause","domain":"power","level":3,"verificationLevel":"collecting","detail":"元器件老化可能导致输出波动和带载能力下降。","layout":{"x":495,"y":245}},
    {"id":"power-redundant","name":"冗余单路损坏","type":"fault_mode","domain":"power","level":3,"verificationLevel":"collecting","detail":"冗余电源的一路失效，系统仍运行但失去冗余能力。","layout":{"x":635,"y":255}},
    {"id":"power-loose-terminal","name":"接线端子松动","type":"fault_cause","domain":"power","level":3,"verificationLevel":"presentation_seed","detail":"接触电阻升高可能引起压降、温升和间歇掉电。","layout":{"x":765,"y":245}},

    {"id":"hardware-cooling","name":"散热组件异常","type":"fault_category","domain":"hardware","level":2,"verificationLevel":"verified_case","knowledgeId":"KB-008","detail":"风扇、风道、滤网和温控链路异常；当前唯一完整案例闭环。","sourceRefs":[{"documentId":"DOC-ADVANTECH-ACP4000-IPC610-UM-ED6","pages":[32,33,39,40,41]},{"documentId":"DOC-ADVANTECH-SAB2000-SM-ED2","pages":[1,2]}],"layout":{"x":795,"y":330}},
    {"id":"hardware-storage","name":"存储硬盘故障","type":"fault_category","domain":"hardware","level":2,"verificationLevel":"presentation_seed","detail":"硬盘物理损坏或状态指示链路故障。","layout":{"x":1090,"y":275}},
    {"id":"hardware-board","name":"主板与底板故障","type":"fault_category","domain":"hardware","level":2,"verificationLevel":"presentation_seed","detail":"短路、静电击穿、插槽和金手指异常。","layout":{"x":1140,"y":390}},
    {"id":"hardware-monitor","name":"监控模块故障","type":"fault_category","domain":"hardware","level":2,"verificationLevel":"official_document","knowledgeId":"KB-008","detail":"接线、测温、拨码、通信或声光告警部件异常。","sourceRefs":[{"documentId":"DOC-ADVANTECH-SAB2000-SM-ED2","pages":[1,2,3]}],"layout":{"x":1100,"y":500}},
    {"id":"hardware-rtc","name":"RTC 电池异常","type":"fault_category","domain":"hardware","level":2,"verificationLevel":"collecting","detail":"电池亏电或替换型号错误导致时间和配置异常。","layout":{"x":1010,"y":545}},
    {"id":"metric-fan-low","name":"风扇转速低于 500 rpm","type":"metric","domain":"hardware","level":3,"verificationLevel":"official_document","knowledgeId":"KB-003","detail":"散热案例的重要异常阈值，用于判断风扇低速。","sourceRefs":[{"documentId":"DOC-ADVANTECH-ACP4000-IPC610-UM-ED6","pages":[39]},{"documentId":"DOC-ADVANTECH-SAB2000-SM-ED2","pages":[1]}],"layout":{"x":750,"y":440}},
    {"id":"alarm-temp-fan","name":"TEMP/FAN 告警","type":"alarm","domain":"monitoring","level":3,"verificationLevel":"official_document","knowledgeId":"KB-002","detail":"温度或风扇状态异常时出现的关键告警；常亮与闪烁用于区分 CPU 侧和系统侧。","sourceRefs":[{"documentId":"DOC-ADVANTECH-ACP4000-IPC610-UM-ED6","pages":[31,39]},{"documentId":"DOC-ADVANTECH-SAB2000-SM-ED2","pages":[1]}],"layout":{"x":875,"y":445}},
    {"id":"action-clean-airflow","name":"清理滤网与风道","type":"action","domain":"hardware","level":3,"verificationLevel":"verified_case","knowledgeId":"KB-007","detail":"断电后清理滤网和进出风通道，并再次测量转速和温度。","sourceRefs":[{"documentId":"DOC-ADVANTECH-ACP4000-IPC610-UM-ED6","pages":[33]},{"documentId":"DOC-ADVANTECH-ACP4000-DS-20250317","pages":[1,2]}],"layout":{"x":720,"y":545}},
    {"id":"safety-poweroff","name":"断电 · 挂牌 · 防静电","type":"safety","domain":"maintenance","level":3,"verificationLevel":"expert_confirmed","knowledgeId":"KB-006","detail":"拆检和更换风扇前必须满足的安全前置条件。","sourceRefs":[{"documentId":"DOC-ADVANTECH-ACP4000-IPC610-UM-ED6","pages":[3,4,5,6,7,8]}],"layout":{"x":580,"y":565}},

    {"id":"maintenance-install","name":"安装错误","type":"fault_category","domain":"maintenance","level":2,"verificationLevel":"presentation_seed","detail":"带电开盖、倒装、固定不足或使用非标配件。","layout":{"x":85,"y":520}},
    {"id":"maintenance-inspection","name":"检修违规","type":"fault_category","domain":"maintenance","level":2,"verificationLevel":"presentation_seed","detail":"长期不清理、热插拔或未按安全流程拆检。","layout":{"x":105,"y":690}},
    {"id":"maintenance-config","name":"参数配置错误","type":"fault_category","domain":"maintenance","level":2,"verificationLevel":"official_document","knowledgeId":"KB-008","detail":"风扇数量、温度传感器数量或 Smart Fan 开关配置与实机不一致。","sourceRefs":[{"documentId":"DOC-ADVANTECH-ACP4000-IPC610-UM-ED6","pages":[40,41]},{"documentId":"DOC-ADVANTECH-SAB2000-SM-ED2","pages":[2,3]}],"layout":{"x":365,"y":740}},
    {"id":"maintenance-parts","name":"配件混用","type":"fault_category","domain":"maintenance","level":2,"verificationLevel":"presentation_seed","detail":"风扇、电源、熔丝或电池规格不匹配。","layout":{"x":465,"y":690}},
    {"id":"maintenance-filter-cycle","name":"长期不清理滤网","type":"maintenance_cause","domain":"maintenance","level":3,"verificationLevel":"expert_confirmed","detail":"会加速滤网积尘并降低进风能力。","layout":{"x":215,"y":565}},

    {"id":"monitor-led","name":"LED 指示失效","type":"fault_category","domain":"monitoring","level":2,"verificationLevel":"official_document","knowledgeId":"KB-002","detail":"状态灯或 LED 板链路异常会削弱视觉告警能力。","sourceRefs":[{"documentId":"DOC-ADVANTECH-ACP4000-IPC610-UM-ED6","pages":[31,39,40]},{"documentId":"DOC-ADVANTECH-SAB2000-SM-ED2","pages":[1]}],"layout":{"x":760,"y":700}},
    {"id":"monitor-buzzer","name":"蜂鸣器线路故障","type":"fault_category","domain":"monitoring","level":2,"verificationLevel":"official_document","knowledgeId":"KB-002","detail":"内置蜂鸣器或 BZ1 接口异常会导致声音告警缺失。","sourceRefs":[{"documentId":"DOC-ADVANTECH-ACP4000-IPC610-UM-ED6","pages":[36,39,40]},{"documentId":"DOC-ADVANTECH-SAB2000-SM-ED2","pages":[1,2]}],"layout":{"x":900,"y":755}},
    {"id":"monitor-bus","name":"SMBus / PMBus 中断","type":"fault_category","domain":"monitoring","level":2,"verificationLevel":"official_document","knowledgeId":"KB-008","detail":"SMBus、PMBus 或远程监控链路异常会导致风扇、温度与电源状态不可见。","sourceRefs":[{"documentId":"DOC-ADVANTECH-ACP4000-IPC610-UM-ED6","pages":[36,37,40]},{"documentId":"DOC-ADVANTECH-SAB2000-SM-ED2","pages":[1,2]}],"layout":{"x":1080,"y":735}},
    {"id":"monitor-reset","name":"告警复位接口故障","type":"fault_category","domain":"monitoring","level":2,"verificationLevel":"official_document","knowledgeId":"KB-002","detail":"ALMRST1 或前面板 Alarm Reset 链路异常会导致无法执行三分钟静音。","sourceRefs":[{"documentId":"DOC-ADVANTECH-ACP4000-IPC610-UM-ED6","pages":[39,40]},{"documentId":"DOC-ADVANTECH-SAB2000-SM-ED2","pages":[1,2]}],"layout":{"x":1160,"y":620}},

    {"id":"hardware-startup","name":"启动与 POST 异常","type":"fault_category","domain":"hardware","level":2,"verificationLevel":"official_document","knowledgeId":"KB-010","detail":"启动未完成时先通过 POST 结果区分正常启动、非致命错误和致命错误。","sourceRefs":[{"documentId":"DOC-ROCKWELL-6177R-UM002F","pages":[81,82,83]}],"layout":{"x":1040,"y":20}},
    {"id":"startup-post-fatal","name":"POST 致命错误","type":"fault_mode","domain":"hardware","level":3,"verificationLevel":"official_document","knowledgeId":"KB-010","detail":"POST 发现致命错误后启动流程中止，需要进入硬件诊断或升级厂家支持。","sourceRefs":[{"documentId":"DOC-ROCKWELL-6300-UM003B","pages":[79]}],"layout":{"x":1180,"y":-35}},
    {"id":"action-isolate-peripherals","name":"逐一隔离外设","type":"action","domain":"maintenance","level":3,"verificationLevel":"official_document","knowledgeId":"KB-010","detail":"断开全部外设后重新上电，再逐一接回以确定是否由外设、线缆或驱动触发。","sourceRefs":[{"documentId":"DOC-ROCKWELL-6177R-UM002F","pages":[82]}],"layout":{"x":535,"y":485}},
    {"id":"maintenance-uefi-config","name":"UEFI 配置异常","type":"fault_category","domain":"maintenance","level":2,"verificationLevel":"official_document","knowledgeId":"KB-011","detail":"错误设置、配置损坏或启动项不匹配可能造成启动失败或错误信息异常。","sourceRefs":[{"documentId":"DOC-ROCKWELL-6177R-UM002F","pages":[84,85]}],"layout":{"x":330,"y":845}},
    {"id":"action-restore-uefi","name":"恢复 UEFI 默认值","type":"action","domain":"maintenance","level":3,"verificationLevel":"official_document","knowledgeId":"KB-011","detail":"配置变更后发生异常时先加载并保存系统默认值；无法进入设置时再按型号流程清除配置。","sourceRefs":[{"documentId":"DOC-ROCKWELL-6300-UM003B","pages":[62,65]}],"layout":{"x":500,"y":845}},
    {"id":"hardware-display","name":"显示与触摸异常","type":"fault_category","domain":"hardware","level":2,"verificationLevel":"official_document","knowledgeId":"KB-012","detail":"包含黑屏、花屏、模糊、抖动、视频噪声以及触摸校准异常。","sourceRefs":[{"documentId":"DOC-ROCKWELL-6300-UM003B","pages":[79,80]}],"layout":{"x":1260,"y":155}},
    {"id":"display-unstable","name":"黑屏 · 花屏 · 抖动","type":"fault_mode","domain":"hardware","level":3,"verificationLevel":"official_document","knowledgeId":"KB-012","detail":"优先核对供电、视频线缆、推荐分辨率、刷新率和线缆干扰。","sourceRefs":[{"documentId":"DOC-ROCKWELL-6300-UM003B","pages":[79,80]}],"layout":{"x":1340,"y":265}},
    {"id":"storage-health-alarm","name":"存储健康异常","type":"alarm","domain":"monitoring","level":3,"verificationLevel":"official_document","knowledgeId":"KB-013","detail":"硬盘健康、读写或系统文件异常需要结合诊断工具、事件日志和备份状态判断。","sourceRefs":[{"documentId":"DOC-ROCKWELL-VERSAVIEW-TG001A","pages":[12,13]}],"layout":{"x":1300,"y":365}},
    {"id":"hardware-memory","name":"内存模块异常","type":"fault_category","domain":"hardware","level":2,"verificationLevel":"official_document","detail":"内存接触、规格或模块故障可能造成 POST 报错、启动失败或运行不稳定。","sourceRefs":[{"documentId":"DOC-ROCKWELL-6177R-UM002F","pages":[40,41]}],"layout":{"x":1270,"y":470}},
    {"id":"rtc-time-loss","name":"日期时间与配置丢失","type":"fault_mode","domain":"hardware","level":3,"verificationLevel":"official_document","knowledgeId":"KB-014","detail":"RTC 电池亏电或更换不当可能造成断电后时间和必要配置无法保持。","sourceRefs":[{"documentId":"DOC-ROCKWELL-6177R-UM002F","pages":[42,43]}],"layout":{"x":1350,"y":560}},
    {"id":"monitor-system-health","name":"系统健康监控","type":"fault_category","domain":"monitoring","level":2,"verificationLevel":"official_document","knowledgeId":"KB-015","detail":"集中查看 CPU/内存利用率、温度、风扇、电压、硬盘、网络和设备信息。","sourceRefs":[{"documentId":"DOC-SCHNEIDER-RACK-1755-05","pages":[142,143,144]}],"layout":{"x":990,"y":850}},
    {"id":"monitor-network-status","name":"网络状态告警","type":"alarm","domain":"monitoring","level":3,"verificationLevel":"official_document","knowledgeId":"KB-015","detail":"监控代理离线、网络不可达或链路异常时进入网络状态告警。","sourceRefs":[{"documentId":"DOC-SCHNEIDER-RACK-1755-05","pages":[142,143]}],"layout":{"x":1310,"y":760}},
    {"id":"monitor-watchdog","name":"看门狗复位","type":"alarm","domain":"monitoring","level":3,"verificationLevel":"official_document","detail":"看门狗可在软件失去响应时触发复位；配置与复位原因需要结合日志判断。","sourceRefs":[{"documentId":"DOC-SCHNEIDER-RACK-1755-05","pages":[147]}],"layout":{"x":830,"y":850}},
    {"id":"action-export-diagnostics","name":"导出诊断与事件日志","type":"action","domain":"monitoring","level":3,"verificationLevel":"official_document","knowledgeId":"KB-010","detail":"保存硬件诊断报告和事件日志，为专家或厂家支持提供可追溯证据。","sourceRefs":[{"documentId":"DOC-ROCKWELL-6177R-UM002F","pages":[83]}],"layout":{"x":665,"y":845}},
    {"id":"maintenance-system-image","name":"系统镜像损坏","type":"fault_category","domain":"maintenance","level":2,"verificationLevel":"official_document","knowledgeId":"KB-016","detail":"异常断电、存储故障或错误升级可能造成系统镜像或文件系统损坏。","sourceRefs":[{"documentId":"DOC-ROCKWELL-6300-UM003B","pages":[54,56,58]}],"layout":{"x":145,"y":845}},
    {"id":"action-restore-image","name":"受控镜像恢复","type":"action","domain":"maintenance","level":3,"verificationLevel":"official_document","knowledgeId":"KB-016","detail":"确认目标磁盘、恢复介质和停机窗口后恢复系统，并复核驱动、应用和业务数据。","sourceRefs":[{"documentId":"DOC-SCHNEIDER-P6-5086-02","pages":[136,140,142]}],"layout":{"x":-20,"y":760}},
    {"id":"maintenance-grounding","name":"接地与安装环境异常","type":"fault_category","domain":"maintenance","level":2,"verificationLevel":"official_document","knowledgeId":"KB-017","detail":"接地不良、固定不足、过度振动、通风孔遮挡或腐蚀环境可能造成间歇故障。","sourceRefs":[{"documentId":"DOC-SCHNEIDER-RACK-1755-05","pages":[47,48]}],"layout":{"x":-70,"y":470}},
    {"id":"hardware-communication","name":"通信接口与外设异常","type":"fault_category","domain":"hardware","level":2,"verificationLevel":"official_document","knowledgeId":"KB-018","detail":"网口、串口、USB、线缆、驱动和外设异常可通过灯态、配置和逐一接回方法隔离。","sourceRefs":[{"documentId":"DOC-ROCKWELL-6300-UM003B","pages":[47,48]}],"layout":{"x":1360,"y":650}}
