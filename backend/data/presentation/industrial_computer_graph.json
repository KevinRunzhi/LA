    {"id":"domain-hardware","name":"硬件部件失效","type":"domain","domain":"hardware","level":1,"verificationLevel":"presentation_seed","detail":"散热、存储、主板、监控模块与电池等部件故障。","layout":{"x":960,"y":155}},
