    {"id":"env-temperature","name":"温度超标","type":"fault_category","domain":"environment","level":2,"verificationLevel":"presentation_seed","detail":"环境高温、低温无加温或存储温区超限。","layout":{"x":75,"y":75}},
    {"id":"env-condensation","name":"湿度凝露","type":"fault_category","domain":"environment","level":2,"verificationLevel":"collecting","detail":"高湿和快速温差变化可能造成板卡凝露与腐蚀。","layout":{"x":75,"y":175}},
    {"id":"env-dust","name":"粉尘堵塞","type":"fault_category","domain":"environment","level":2,"verificationLevel":"collecting","detail":"滤网长期不清理或无防尘措施导致进风阻力升高。","layout":{"x":115,"y":285}},
    {"id":"env-vibration","name":"振动冲击","type":"fault_category","domain":"environment","level":2,"verificationLevel":"presentation_seed","detail":"固定不良、搬运不当或现场振动影响机械连接。","layout":{"x":255,"y":325}},
    {"id":"env-high-heat","name":"高温堵风道","type":"fault_mode","domain":"environment","level":3,"verificationLevel":"presentation_seed","detail":"高环境温度叠加风道受阻，导致散热余量不足。","layout":{"x":35,"y":25}},
    {"id":"env-board-moisture","name":"板卡凝露","type":"fault_mode","domain":"environment","level":3,"verificationLevel":"collecting","detail":"凝露可能造成绝缘下降、腐蚀和启动不稳定。","layout":{"x":35,"y":225}},
    {"id":"env-filter-dust","name":"滤网积尘","type":"fault_cause","domain":"environment","level":3,"verificationLevel":"verified_case","detail":"当前散热案例已验证的进风阻力来源之一。","layout":{"x":80,"y":365}},

    {"id":"power-mains","name":"外部市电异常","type":"fault_category","domain":"power","level":2,"verificationLevel":"presentation_seed","detail":"电压超范围、接地缺失或电源线破损。","layout":{"x":420,"y":40}},
    {"id":"power-module","name":"电源本体异常","type":"fault_category","domain":"power","level":2,"verificationLevel":"collecting","detail":"电源老化、冗余单路损坏或替换件不匹配。","layout":{"x":535,"y":185}},
    {"id":"power-distribution","name":"配电附件异常","type":"fault_category","domain":"power","level":2,"verificationLevel":"presentation_seed","detail":"保险丝规格、接线松动和极性错误。","layout":{"x":690,"y":180}},
